---
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import "../styles/global.css";

interface Props {
  pageTitle?: string;
  description?: string;
  robots?: string;
  signalField?: boolean;
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: "website" | "profile" | "article";
  schemaType?: "WebPage" | "ProfilePage" | "CollectionPage" | "BlogPosting";
  headline?: string;
  publishedTime?: string;
  modifiedTime?: string;
  section?: string;
  tags?: string[];
}

const {
  pageTitle = "Dustin Deus",
  description = "Dustin Deus — founder and engineer. Former co-founder & CTO at WunderGraph. Now Principal Engineer at OpenCode.",
  robots = "index, follow",
  signalField = false,
  ogImage: ogImageProp,
  ogImageAlt,
  ogType = "profile",
  schemaType,
  headline,
  publishedTime,
  modifiedTime,
  section,
  tags = [],
} = Astro.props;

const site = Astro.site ?? new URL(Astro.url.origin);
const canonical = new URL(Astro.url.pathname, site).toString();
const siteRoot = new URL("/", site).toString();
const personId = new URL("/#person", site).toString();
const websiteId = new URL("/#website", site).toString();
const webPageId = `${canonical}#webpage`;

/** Per-page social preview image, generated at build time by /og/*.png.
 *  - `/`              → `/og/index.png`
 *  - `/blog`          → `/og/blog.png`
 *  - `/blog/<slug>`   → `/og/blog/<slug>.png`
 *  - anything else    → static fallback
 */
function ogImagePath(pathname: string): string {
  const clean = pathname.replace(/\/$/, "");
  if (clean === "") return "/og/index.png";
  if (clean === "/blog") return "/og/blog.png";
  if (clean.startsWith("/blog/")) return `/og${clean}.png`;
  return "/builder-background.webp";
}
const ogImage = new URL(
  ogImageProp ?? ogImagePath(Astro.url.pathname),
  site,
).toString();
const imageAlt = ogImageAlt ?? `Social preview for ${pageTitle}`;

/** Markdown counterpart of the current page, for LLM ingestion.
 *  - `/`              → `/index.md`
 *  - `/blog/`         → `/blog.md`
 *  - `/blog/<slug>/`  → `/blog/<slug>.md`
 *  - `/404`           → no alternate
 */
function markdownAlternate(pathname: string): string | null {
  if (pathname.startsWith("/404")) return null;
  const clean = pathname.replace(/\/$/, "");
  if (clean === "") return "/index.md";
  if (clean === "/blog") return "/blog.md";
  if (clean.startsWith("/blog/")) return `${clean}.md`;
  return null;
}
const mdPath = markdownAlternate(Astro.url.pathname);
const mdUrl = mdPath ? new URL(mdPath, site).toString() : null;

const effectiveSchemaType =
  schemaType ?? (ogType === "article" ? "BlogPosting" : ogType === "profile" ? "ProfilePage" : "WebPage");
const pageHeadline = headline ?? pageTitle;

const personSchema = {
  "@type": "Person",
  "@id": personId,
  name: "Dustin Deus",
  givenName: "Dustin",
  familyName: "Deus",
  alternateName: "StarpTech",
  jobTitle: "Principal Engineer",
  description:
    "Founder and engineer. Former co-founder & CTO at WunderGraph. Principal Engineer at OpenCode.",
  email: "mailto:deusdustin@gmail.com",
  image: new URL("/icon.svg", site).toString(),
  worksFor: {
    "@type": "Organization",
    name: "OpenCode",
    url: "https://opencode.ai/",
  },
  url: siteRoot,
  sameAs: [
    "https://github.com/StarpTech",
    "https://www.linkedin.com/in/dustin-deus/",
    "https://opencode.ai/",
    "https://wundergraph.com",
  ],
};

const websiteSchema = {
  "@type": "WebSite",
  "@id": websiteId,
  name: "Dustin Deus",
  alternateName: "StarpTech",
  url: siteRoot,
  inLanguage: "en",
  publisher: { "@id": personId },
};

const pageSchema = {
  "@type": effectiveSchemaType,
  "@id": webPageId,
  url: canonical,
  name: pageTitle,
  headline: pageHeadline,
  description,
  image: ogImage,
  inLanguage: "en",
  isPartOf: { "@id": websiteId },
  ...(effectiveSchemaType === "ProfilePage" ? { mainEntity: { "@id": personId } } : {}),
  ...(effectiveSchemaType === "BlogPosting"
    ? {
        mainEntityOfPage: { "@id": webPageId },
        author: { "@id": personId },
        publisher: { "@id": personId },
        datePublished: publishedTime,
        dateModified: modifiedTime ?? publishedTime,
        articleSection: section,
        keywords: tags.length ? tags.join(", ") : section,
      }
    : {}),
};

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [personSchema, websiteSchema, pageSchema],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="description" content={description} />
    <meta name="author" content="Dustin Deus" />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0a0a0a" media="(prefers-color-scheme: dark)" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <link rel="mask-icon" href="/icon-mask.svg" color="#2563eb" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" href="/rss.xml" title="Dustin Deus — Writing" />
    {mdUrl && (
      <link rel="alternate" type="text/markdown" href={mdUrl} title="Markdown" />
    )}

    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Geist-Regular.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/Geist-SemiBold.woff2"
      crossorigin
    />
    <link
      rel="preload"
      as="font"
      type="font/woff2"
      href="/fonts/GeistMono-Regular.woff2"
      crossorigin
    />

    <title>{pageTitle}</title>

    <meta property="og:type" content={ogType} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:site_name" content="Dustin Deus" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    {ogType === "profile" && <meta property="profile:first_name" content="Dustin" />}
    {ogType === "profile" && <meta property="profile:last_name" content="Deus" />}
    {ogType === "profile" && <meta property="profile:username" content="StarpTech" />}
    {ogType === "article" && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && (modifiedTime ?? publishedTime) && <meta property="article:modified_time" content={modifiedTime ?? publishedTime} />}
    {ogType === "article" && <meta property="article:author" content="https://starptech.com/" />}
    {ogType === "article" && section && <meta property="article:section" content={section} />}
    {ogType === "article" && tags.map((tag) => <meta property="article:tag" content={tag} />)}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@StarpTech" />
    <meta name="twitter:creator" content="@StarpTech" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <script is:inline>
      try {
        const saved = localStorage.getItem("theme");
        if (saved === "dark" || saved === "light") {
          document.documentElement.dataset.theme = saved;
        } else {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          if (prefersDark) document.documentElement.dataset.theme = "dark";
        }
      } catch {}
    </script>

    <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
  </head>
  <body>
    {signalField && (
      <div class="signal-field" aria-hidden="true">
        <canvas id="signalField"></canvas>
      </div>
    )}
    <slot />
    <Footer />
    <ThemeToggle />
    <script>
      import "../scripts/agent.client.ts";
      import "../scripts/inference-viz.client.ts";
      import "../scripts/signal-field.client.ts";
    </script>
  </body>
</html>
